rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /commitments/{commitmentId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
        
        allow create, update: if request.auth != null && request.auth.uid == userId &&
          (!('lastEvaluatedAt' in request.resource.data) || 
           request.resource.data.lastEvaluatedAt == (resource == null ? null : resource.data.lastEvaluatedAt)) &&
          (!('isDirty' in request.resource.data) || 
           request.resource.data.isDirty == true || 
           request.resource.data.isDirty == (resource == null ? true : resource.data.isDirty));
      }

      match /{allChildren=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
